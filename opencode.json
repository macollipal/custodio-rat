{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git add *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "git pull *": "ask",
      "git checkout *": "ask",
      "git merge *": "ask",
      "git stash *": "ask",
      "git restore *": "ask",
      "git rebase *": "ask",
      "git cherry-pick *": "ask",
      "git reset *": "ask",
      "git rm *": "ask",
      "git mv *": "ask",
      "*": "allow"
    },
    "edit": "ask",
    "todowrite": "ask"
  }
}
