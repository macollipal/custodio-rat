{
  "version": 2,
  "root": ".",
  "projects": [
    {
      "path": "frontend-next",
      "settings": {
        "framework": "nextjs"
      }
    }
  ],
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend-next/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend-next/$1"
    }
  ]
}
