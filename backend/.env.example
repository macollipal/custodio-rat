# API Keys — MiniMax (primario) / OpenAI (fallback opcional)
MINIMAX_API_KEY=tu_api_key_aqui
MINIMAX_MODEL=MiniMax-M2.7

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# JWT - GENERAR UNA CLAVE SECRETA LARGA Y ALEATORIA
# En Linux/Mac: openssl rand -hex 64
# En Windows PowerShell: $bytes = New-Object byte[] 32; (New-Object System.Security.Cryptography.RandomNumberGenerator).GetBytes($bytes); [BitConverter]::ToString($bytes) -replace '-', ''
SECRET_KEY=cambia-esta-clave-en-produccion-por-una-de-256-bits

# Encryption Key (Fernet) — OBLIGATORIO en producción para cifrar datos en reposo
# Generar clave: cd backend && python -c "from app.core.crypto import generate_key; print(generate_key())"
# En desarrollo es opcional (fallback: datos sin cifrar)
ENCRYPTION_KEY=

# Ambiente: development | production
# En producción, el admin inicial NO se crea automáticamente
ENVIRONMENT=development

# Dominios permitidos para CORS (OBLIGATORIO en todos los ambientes)
# Formato: origen1,origen2,origen3 (sin espacios)
# QA:     ALLOWED_ORIGINS=https://custodio-qa.vercel.app,http://localhost:3000
# Prod:   ALLOWED_ORIGINS=https://custodio-rat.vercel.app
ALLOWED_ORIGINS=

# ─── Base de datos ────────────────────────────────────────────
# Desarrollo (SQLite local):
#   DATABASE_URL=sqlite:///database.db
#
# Producción (Neon PostgreSQL):
#   DATABASE_URL=postgresql://user:password@ep-xxx-xxx-123456.neon.tech/custodio?sslmode=require
#
# Para obtener la URL de Neon:
#   1. Ve a console.neon.tech → tu proyecto → Connection Details
#   2. Copia la URL completa (reemplaza <password> con tu contraseña)
DATABASE_URL=sqlite:///database.db